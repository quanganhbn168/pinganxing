<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preserve the Authorization header for API/authentication requests.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Keep public/index.php out of browser URLs in a single redirect.
    RewriteCond %{THE_REQUEST} \s/+public/index\.php(?:[?\s]) [NC]
    RewriteRule ^public/index\.php$ / [R=301,L]

    # Keep public out of browser URLs when somebody accesses it directly.
    RewriteCond %{THE_REQUEST} \s/+public(?:[/?\s]) [NC]
    RewriteRule ^public(?:/(.*))?$ /$1 [R=301,L,NE]

    # Remove index.php from direct browser URLs.
    RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s]) [NC]
    RewriteRule ^index\.php$ / [R=301,L]

    # Stop a second root-level rewrite after routing into public.
    RewriteRule ^public(?:/|$) - [L]

    # Route every request through Laravel's public directory.
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^(.+)$ public/$1 [L]
</IfModule>

<IfModule mod_negotiation.c>
    Options -MultiViews -Indexes
</IfModule>

# Prevent Apache from serving common project metadata if rewrite rules are unavailable.
<FilesMatch "^(?:\.env|\.git|artisan|composer\.(?:json|lock)|package(?:-lock)?\.json|phpunit\.xml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
